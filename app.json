{
  "expo": {
    "name": "RunTracker",
    "slug": "runtracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "runtracker",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.runtracker.app",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RunTracker needs your location to track your running route in the background.",
        "NSLocationWhenInUseUsageDescription": "RunTracker needs your location to show your position on the map.",
        "NSLocationAlwaysUsageDescription": "RunTracker needs background location to track your runs even when the app is in the background.",
        "UIBackgroundModes": ["location", "audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.runtracker.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RunTracker to track your running route in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-secure-store",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow RunTracker to access your motion data for step counting."
        }
      ]
    ]
  }
}
